# ─────────────────────────────────────────────────────────────
# MECANICO MANAGEMENT — Variables de entorno
# Copia este archivo a .env.local y llena los valores reales
# NUNCA commitees .env.local al repositorio
# ─────────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ──
# Obtén estos valores en: https://supabase.com → Project Settings → Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.kefazyphwvyhdmqzudyp.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.kefazyphwvyhdmqzudyp.supabase.co:5432/postgres"

# ── NextAuth ──
# En producción: NEXTAUTH_URL = tu dominio de Vercel
NEXTAUTH_URL="http://localhost:3000"
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="REEMPLAZA_CON_SECRETO_GENERADO"

# ── Resend (email) ──
# Obtén tu API key en: https://resend.com
RESEND_API_KEY="re_REEMPLAZA_CON_TU_API_KEY"
EMAIL_FROM="Mecanico Carlos <noreply@tudominio.com>"
ACCOUNTANT_EMAIL="contadora@ejemplo.com"

# ── Supabase Storage ──
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="REEMPLAZA_CON_SERVICE_ROLE_KEY"

# ── Google Drive (Service Account) ──
# Crea una cuenta de servicio en Google Cloud Console
# Comparte tu carpeta de Drive con el email de la cuenta de servicio
GOOGLE_SERVICE_ACCOUNT_EMAIL="mi-cuenta@proyecto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREEMPLAZA_CON_TU_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID="REEMPLAZA_CON_ID_DE_LA_CARPETA_COMPARTIDA"

# ── Vercel Cron (protección del endpoint de recordatorios) ──
# Genera con: openssl rand -hex 32
CRON_SECRET="REEMPLAZA_CON_SECRETO_GENERADO"
